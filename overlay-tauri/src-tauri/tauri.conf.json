{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PoE Leveling Overlay",
  "version": "0.1.0",
  "identifier": "com.poeleveling.overlay-tauri",
  "build": {
    "beforeDevCommand": "npm run vite-dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run vite-build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PoE Leveling Overlay",
        "width": 380,
        "height": 600,
        "minWidth": 280,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"],
    "icon": ["../../common/icons/icon.ico"],
    "resources": {
      "../../common/data/routes": "common-data/routes"
    }
  }
}
